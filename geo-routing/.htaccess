# WC2026 Players / Top Teams
# Geo-language routing for Apache + PHP on regular hosting
# Requirements:
# - mod_rewrite enabled
# - PHP enabled
# - Cloudflare IP Geolocation enabled so origin receives CF-IPCountry
# Docs confirm CF-IPCountry is added when IP Geolocation is enabled. [web:42][web:36]
# Apache SetEnvIf/SetEnvIfNoCase can read request headers such as Accept-Language. [web:146]

Options -MultiViews
RewriteEngine On

# --------------------------------------------------
# 1) Never rewrite real files or directories
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --------------------------------------------------
# 2) Exclude static assets and utility endpoints
# --------------------------------------------------
RewriteRule ^(assets|images|css|js|fonts|uploads)/ - [L,NC]
RewriteRule ^(favicon\.ico|robots\.txt|sitemap\.xml)$ - [L,NC]

# --------------------------------------------------
# 3) Language switch endpoint
# Example: /lang-switch.php?lang=es&return=/teams/
# --------------------------------------------------
RewriteRule ^lang-switch/?$ /lang-switch.php [L,QSA,NC]

# --------------------------------------------------
# 4) Geo-language routing only for root-level entry pages
#    This prevents redirect loops on language-prefixed URLs.
# --------------------------------------------------
RewriteCond %{REQUEST_URI} ^/?$ [OR]
RewriteCond %{REQUEST_URI} ^/(players|teams|world-cup-2026-format|host-cities|faq)/?$ [NC]
RewriteRule ^ index.php [L]

# --------------------------------------------------
# 5) Optional: pass Accept-Language into env flags for debugging or app logic
# --------------------------------------------------
<IfModule mod_setenvif.c>
    SetEnvIfNoCase Accept-Language "^es" PREFERRED_LANG=es
    SetEnvIfNoCase Accept-Language "^pt" PREFERRED_LANG=pt
    SetEnvIfNoCase Accept-Language "^fr" PREFERRED_LANG=fr
    SetEnvIfNoCase Accept-Language "^de" PREFERRED_LANG=de
    SetEnvIfNoCase Accept-Language "^ru" PREFERRED_LANG=ru
    SetEnvIfNoCase Accept-Language "^en" PREFERRED_LANG=en
</IfModule>

# --------------------------------------------------
# 6) Cache safety for dynamic routing responses
#    Routing pages vary by Cookie, Accept-Language, and CF-IPCountry.
# --------------------------------------------------
<IfModule mod_headers.c>
    <FilesMatch "^(index|lang-switch)\.php$">
        Header always set Vary "Accept-Language, CF-IPCountry, Cookie"
        Header always set Cache-Control "private, no-store, max-age=0"
    </FilesMatch>
</IfModule>
